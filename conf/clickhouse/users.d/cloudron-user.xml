<?xml version="1.0"?>
<!-- Langfuse connects to ClickHouse as CLICKHOUSE_USER (default "clickhouse") with CLICKHOUSE_PASSWORD.
     The password is read from the environment at CH startup so it is never baked into the image. -->
<clickhouse>
    <users>
        <clickhouse>
            <password from_env="CLICKHOUSE_PASSWORD"/>
            <networks>
                <ip>127.0.0.1</ip>
                <ip>::1</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
            <named_collection_control>1</named_collection_control>
        </clickhouse>
    </users>
</clickhouse>
